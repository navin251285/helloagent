# ── telegram-bot ──────────────────────────────────────────────────────────────
# Telegram bot token obtained from @BotFather
BOT_TOKEN=your-telegram-bot-token-here

# RAG API endpoint the telegram-bot forwards questions to
RAG_API_URL=http://127.0.0.1:8000/ask

# ── rag-api (optional overrides, defaults already point to localhost) ──────────
VECTOR_DB_URL=http://127.0.0.1:8002
LLM_SERVICE_URL=http://127.0.0.1:8001

# ── rag-api (optional tunables) ────────────────────────────────────────────────
# VECTOR_QUERY_PATH=/query
# LLM_ASK_PATH=/ask
# REQUEST_TIMEOUT_SECONDS=120
# DEFAULT_TOP_K=5
# DEFAULT_MAX_TOKENS=400
